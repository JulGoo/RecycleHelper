<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".PetActivity">

    <TextView
        android:id="@+id/tv_pet"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        android:text="플라스틱 용기"
        android:textColor="@color/black"
        android:textSize="60sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:id="@+id/sv_pet"
        android:layout_width="409dp"
        android:layout_height="591dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_pet">

        <TextView
            android:id="@+id/tv_pet2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="패트병류\n\n- 내용물을 비우고 깨끗이 헹군 후 배출합니다. 라벨(종이, 비닐 등)과 뚜껑은 제거 후 각각 배출해주세요. 압착하여 부피를 줄인 후 배출하면 더 좋습니다.\n\n플라스틱\n\n- 음식 용기, 세제 용기 등은 내용물을 비우고 헹군 후 배출해주세요. 이물질이 많이 묻어 있는 경우 일반 쓰레기로 처리합니다. 펌핑 용기의 경우 내부 철제 스프링이 부착된 펌프는 제거하여 배출합니다.\n\n재활용 안 되는 것\n\n- 오염된 플라스틱(음식물, 기름 등이 묻은 플라스틱)\n- 1회용 젓가락, 일회용 컵, 일회용 수저 등 재활용이 어려운 플라스틱 제품\n- CD 케이스, 볼펜 등 복합재질의 플라스틱 제품"
            android:textSize="20sp" />
        />
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>