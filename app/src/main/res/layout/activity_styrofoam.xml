<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".StyrofoamActivity">

    <TextView
        android:id="@+id/tv_styrofoam"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        android:contentDescription="스티로폼"
        android:text="스티로폼"
        android:textColor="@color/black"
        android:textSize="60sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:id="@+id/sv_styrofoam"
        android:layout_width="409dp"
        android:layout_height="591dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_styrofoam">

        <TextView
            android:id="@+id/tv_strofoam2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="스티로폼\n\n- 스티로폼 포장재는 이물질이 없도록 깨끗이 세척한 후 배출합니다. 스티커나 테이프 등 다른 재질은 제거한 후 배출합니다. 부피가 큰 스티로폼은 압축하여 배출하면 더 좋습니다.\n\n스티로폼 박스\n\n- 과일이나 생선 등의 운반용 스티로폼 박스는 내용물을 비우고, 내부를 깨끗하게 세척한 후 배출합니다. 박스에 붙어 있는 테이프, 라벨, 기타 이물질을 제거한 후 배출해주세요.\n\n재활용 안 되는 것\n\n- 오염된 스티로폼(음식물, 기름 등이 묻은 스티로폼)\n- 코팅된 스티로폼(방수 처리된 스티로폼 등)\n- 파손된 스티로폼(부서진 작은 조각 등)\n- 건축 자재용 스티로폼"
            android:textSize="20sp" />
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>