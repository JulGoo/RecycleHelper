<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
xmlns:tools="http://schemas.android.com/tools"
android:id="@+id/main"
android:layout_width="match_parent"
android:layout_height="match_parent"
tools:context=".MainActivity"
    >

    <Button
        android:id="@+id/btn_image_search"
        android:layout_width="350dp"
        android:layout_height="195dp"
        android:layout_marginTop="28dp"
        android:background="@drawable/images"
        android:gravity="center_horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.491"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_recycleHelper" />

    <Button
    android:id="@+id/btn_notice"
    android:layout_width="160dp"
    android:layout_height="240dp"
    android:background="@drawable/announcement2"
    android:layout_marginTop="30dp"
    app:layout_constraintEnd_toEndOf="@+id/btn_image_search"
    app:layout_constraintTop_toBottomOf="@+id/btn_image_search" />

<Button
    android:id="@+id/btn_recycling_guide"
    android:layout_width="160dp"
    android:layout_height="240dp"
    android:background="@drawable/recycletip"
    android:layout_marginTop="30dp"
    app:layout_constraintStart_toStartOf="@+id/btn_image_search"
    app:layout_constraintTop_toBottomOf="@+id/btn_image_search" />

<TextView
    android:id="@+id/tv_recycleHelper"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="분리도우미"
    android:textColor="@color/black"
    android:textSize="60sp"
    android:textStyle="bold"
    android:layout_marginTop="50dp"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>